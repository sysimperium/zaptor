# Variáveis de Ambiente - ZapTor Backend
# Copie este arquivo para .env e preencha com seus valores reais

# ── Railway / Servidor ────────────────────────────────────────
# A porta é definida automaticamente pelo Railway (não altere em produção)
PORT=3001

# ── Supabase ──────────────────────────────────────────────────
# Encontre em: Supabase → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Configuração da Empresa ────────────────────────────────────
# Deve ser igual ao "slug" cadastrado na tabela companies do Supabase
COMPANY_SLUG=minha-empresa

# ── Chave do Admin ────────────────────────────────────────────
# Esta é a "senha" para acessar o painel de administração no frontend
# Troque por algo seguro antes de publicar!
ADMIN_KEY=SuaSenhaAdminAqui

# ── Puppeteer (preenchido automaticamente no Docker/Railway) ──
# Só altere se souber o que está fazendo
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
